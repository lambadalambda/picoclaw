# Picoclaw Docker environment variables
# Copy this file to .env and fill in your values.
#
# All config.json fields can be overridden via PICOCLAW_* env vars.
# See: https://github.com/sipeed/picoclaw#configuration

# --- Docker Runtime ---
# Optional overrides so multiple local checkouts can run at once.
# PICOCLAW_CONTAINER_NAME=picoclaw-alice
# PICOCLAW_DELTACHAT_CONTAINER_NAME=picoclaw-alice-deltachat
# PICOCLAW_RESTORE_APT_PACKAGES=true
# PICOCLAW_APT_RESTORE_MARKER_FILE=/opt/picoclaw/.apt-restore.done
# Workspace service supervisor (runit).
# Starts runsvdir so the agent can manage long-running services by writing
# service definitions under workspace/services/.
# PICOCLAW_SERVICES_ENABLED=true
# PICOCLAW_SERVICES_DIR=/root/.picoclaw/workspace/services
# PICOCLAW_SERVICES_LOG=/root/.picoclaw/workspace/memory/services-supervisor.log
# Optional explicit timezone override for containers.
# If unset, docker-compose binds host /etc/localtime into containers.
# TZ=Asia/Dubai
# Minimum free KB required before startup APT rehydrate runs.
# If free space is lower, restore is skipped and retried on next start.
# PICOCLAW_APT_RESTORE_MIN_FREE_KB=20480

# --- Model ---
# The model name determines which provider is used.
# Prefixed names (anthropic/*, openai/*, google/*, etc.) route through OpenRouter.
# Direct names like "claude-3.5-sonnet" route to the matching provider's own API.
#
# Examples for OpenRouter:
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
#   google/gemini-2.5-pro
#   deepseek/deepseek-chat
#
# PICOCLAW_AGENTS_DEFAULTS_MODEL=anthropic/claude-sonnet-4-20250514
# PICOCLAW_AGENTS_DEFAULTS_MAX_TOKENS=200000
# Request payload budgeting is disabled by default.
# Uncomment one or more limits below to enable it.
# PICOCLAW_AGENTS_DEFAULTS_REQUEST_MAX_MESSAGES=200
# PICOCLAW_AGENTS_DEFAULTS_REQUEST_MAX_TOTAL_CHARS=160000
# PICOCLAW_AGENTS_DEFAULTS_REQUEST_MAX_MESSAGE_CHARS=12000
# PICOCLAW_AGENTS_DEFAULTS_REQUEST_MAX_TOOL_MESSAGE_CHARS=6000
# PICOCLAW_AGENTS_DEFAULTS_SUBAGENT_MAX_TASKS=200
# PICOCLAW_AGENTS_DEFAULTS_SUBAGENT_COMPLETED_TTL_SECONDS=86400

# --- LLM Providers ---
# PICOCLAW_PROVIDERS_ANTHROPIC_API_KEY=sk-ant-xxx
# PICOCLAW_PROVIDERS_OPENAI_API_KEY=sk-xxx
# PICOCLAW_PROVIDERS_OPENROUTER_API_KEY=sk-or-v1-xxx
# PICOCLAW_PROVIDERS_GROQ_API_KEY=gsk_xxx
# PICOCLAW_PROVIDERS_ZHIPU_API_KEY=xxx
# PICOCLAW_PROVIDERS_MODAL_API_KEY=modal_xxx
# PICOCLAW_PROVIDERS_MODAL_API_BASE=https://api.us-west-2.modal.direct/v1

# --- Channels ---
# PICOCLAW_CHANNELS_TELEGRAM_ENABLED=true
# PICOCLAW_CHANNELS_TELEGRAM_TOKEN=your-bot-token
# PICOCLAW_CHANNELS_TELEGRAM_ALLOW_FROM=123456789

# PICOCLAW_CHANNELS_DISCORD_ENABLED=true
# PICOCLAW_CHANNELS_DISCORD_TOKEN=your-bot-token

# PICOCLAW_CHANNELS_DELTACHAT_ENABLED=true
# If using the optional deltachat compose profile, use service DNS name:
# PICOCLAW_CHANNELS_DELTACHAT_BRIDGE_URL=ws://deltachat-bridge:3100
# PICOCLAW_CHANNELS_DELTACHAT_ALLOW_FROM=alice@example.org
# Optional DeltaChat reactions (emoji strings; empty disables)
# PICOCLAW_CHANNELS_DELTACHAT_ACK_REACTION=<emoji>
# PICOCLAW_CHANNELS_DELTACHAT_DONE_REACTION=<emoji>
# PICOCLAW_CHANNELS_DELTACHAT_ERROR_REACTION=<emoji>
# Forward inbound reaction events to the agent as messages (default: false)
# PICOCLAW_CHANNELS_DELTACHAT_FORWARD_REACTIONS=false

# --- DeltaChat Bridge (optional docker profile: deltachat) ---
# DELTACHAT_SETUP_QR=DCACCOUNT:https://nine.testrun.org/new
# DELTACHAT_DISPLAY_NAME=Alice
# DELTACHAT_BRIDGE_HOST=0.0.0.0
# DELTACHAT_BRIDGE_PORT=3100
# DELTACHAT_ACCOUNTS_DIR=/accounts
# DELTACHAT_RPC_SERVER_PATH=/root/.local/deltachat-bridge-venv/bin/deltachat-rpc-server
# DELTACHAT_BRIDGE_READY_FILE=/tmp/deltachat-bridge.ready
# DELTACHAT_CONTACT_QR_TEXT_FILE=/root/.picoclaw/deltachat-contact.qr.txt
# DELTACHAT_CONTACT_QR_SVG_FILE=/root/.picoclaw/deltachat-contact.qr.svg
#
# Optional alternative to QR setup:
# DELTACHAT_EMAIL=alice@nine.testrun.org
# DELTACHAT_PASSWORD=your-mail-password

# --- Tools ---
# PICOCLAW_TOOLS_WEB_SEARCH_API_KEY=your-brave-api-key
# Web search backend: auto (prefer z.ai when any z.ai/zhipu/modal key is available), brave, zai
# PICOCLAW_TOOLS_WEB_SEARCH_PROVIDER=auto
# Z.AI web search settings (direct API /paas/v4/web_search)
# Optional if you already configured providers.zhipu.api_key or providers.modal.api_key
# PICOCLAW_TOOLS_WEB_SEARCH_ZAI_API_KEY=your-zai-api-key
# PICOCLAW_TOOLS_WEB_SEARCH_ZAI_API_BASE=https://api.z.ai/api
# MCP endpoint (used before direct /paas/v4/web_search)
# PICOCLAW_TOOLS_WEB_SEARCH_ZAI_MCP_URL=https://api.z.ai/api/mcp/web_search_prime/mcp
# Optional region hint for MCP search: us or cn
# PICOCLAW_TOOLS_WEB_SEARCH_ZAI_LOCATION=us
# PICOCLAW_TOOLS_WEB_SEARCH_ZAI_SEARCH_ENGINE=search-prime
# PICOCLAW_TOOLS_POLICY_ENABLED=false
# PICOCLAW_TOOLS_POLICY_SAFE_MODE=false
# PICOCLAW_TOOLS_POLICY_ALLOW=read_file,list_dir
# PICOCLAW_TOOLS_POLICY_DENY=exec,write_file
# Vision fallback for image attachments (e.g. GLM-5)
# PICOCLAW_TOOLS_VISION_ENABLED=true
# PICOCLAW_TOOLS_VISION_MODEL=glm-4.6v
# Optional: overrides provider.zhipu credentials for vision fallback
# PICOCLAW_TOOLS_VISION_API_KEY=your-zai-or-zhipu-key
# PICOCLAW_TOOLS_VISION_API_BASE=https://open.bigmodel.cn/api/paas/v4
# PICOCLAW_TOOLS_VISION_TIMEOUT_SECONDS=45
# PICOCLAW_TOOLS_VISION_MAX_IMAGES=3
